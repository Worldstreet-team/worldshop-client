# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=WorldShop
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_GUEST_CHECKOUT=true
VITE_ENABLE_WISHLIST=true

# Pagination
VITE_DEFAULT_PAGE_SIZE=12

# Image Placeholders
VITE_PLACEHOLDER_IMAGE=/images/placeholder-product.png

# External Auth Service Configuration
VITE_AUTH_SERVICE_URL=https://api.worldstreetgold.com
VITE_LOGIN_URL=https://worldstreetgold.com/login
VITE_REGISTER_URL=https://worldstreetgold.com/register

